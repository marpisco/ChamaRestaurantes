# SIP Extension
SIP_HOST=192.168.1.100
SIP_PORT=5060
SIP_USERNAME=1001
SIP_PASSWORD=secret
SIP_LOCAL_IP=192.168.1.50
SIP_LOCAL_PORT=5080

# Groq API (LLM + Whisper STT)
GROQ_API_KEY=gsk_...

# OpenAI API (TTS — sem limites restritivos, suporte PT-PT)
OPENAI_API_KEY=sk-...
# Modelo: tts-1 (rápido) ou tts-1-hd (melhor qualidade)
OPENAI_TTS_MODEL=tts-1
# Vozes: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_VOICE=nova

# Servidor
PORT=3000
